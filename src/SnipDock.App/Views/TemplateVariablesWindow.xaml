<Window x:Class="SnipDock.App.Views.TemplateVariablesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SnipDock" Height="530" Width="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="/Resources/Icons/app.ico">

    <Window.Resources>
        <Style x:Key="DialogAccentButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogPrimaryButtonStyle}" />
        <Style x:Key="DialogSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}" />
    </Window.Resources>

    <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="12" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Color="#000000" Opacity="0.28"/>
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseDown="TitleBar_MouseDown" Background="Transparent">
                <TextBlock x:Name="TxtTitle" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Left" />
                <Button x:Name="BtnCloseCancel" Click="Cancel_Click" Style="{StaticResource CloseIconButtonStyle}" HorizontalAlignment="Right" FontSize="13" Width="30" Height="30" ToolTip="Close" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,14,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="190" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource SettingsSectionStyle}" Padding="12" Margin="0,0,0,12">
                    <TextBlock x:Name="TxtHint" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12.5" TextWrapping="Wrap" />
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="VariablesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="155" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource PillBadgeStyle}" Margin="0,0,12,0" Padding="8,5">
                                        <TextBlock Text="{Binding Name}" ToolTip="{Binding Name}" Foreground="{DynamicResource AccentColorTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Padding="10,6" MinHeight="34" VerticalContentAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock x:Name="TxtPreviewLabel" Grid.Row="2" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12.5" FontWeight="SemiBold" Margin="0,6,0,6" />

                <Border Grid.Row="3" Style="{StaticResource PanelCardStyle}" Padding="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                        <TextBox x:Name="PreviewBox" Style="{x:Null}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="12.5" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" />
                    </ScrollViewer>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel" Click="Cancel_Click" Style="{StaticResource DialogSecondaryButtonStyle}" Margin="0,0,10,0" />
                <Button x:Name="BtnConfirm" Click="Confirm_Click" Style="{StaticResource DialogAccentButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
