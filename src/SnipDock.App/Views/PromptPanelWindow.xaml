<Window x:Class="SnipDock.App.Views.PromptPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Loc[WindowTitle]}" 
        Height="540" Width="820"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        PreviewKeyDown="Window_PreviewKeyDown">
    
    <Window.Resources>
        <!-- Custom ListBoxItem Style for Premium Card Look -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="CardBorder" Background="{DynamicResource ThemeCardBackgroundBrush}" CornerRadius="8" Padding="12" 
                                BorderThickness="1.5" BorderBrush="Transparent" SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ThemeCardHoverBrush}" />
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource AccentColorSelectedBgBrush}" />
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentColorBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Circular Accent Color Badges -->
        <Style x:Key="ColorBadgeStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <!-- Circle Outline when checked -->
                            <Ellipse x:Name="Outline" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="2" Margin="-3" Visibility="Collapsed" />
                            <!-- Main Colored Circle -->
                            <Ellipse Fill="{TemplateBinding Background}" />
                            <!-- A tiny inner white dot when checked -->
                            <Ellipse x:Name="Dot" Fill="#ffffff" Width="6" Height="6" Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Outline" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Dot" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outline" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Outline" Property="Stroke" Value="{DynamicResource AccentColorBrushMouseOver}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Settings Buttons secondary style -->
        <Style x:Key="SettingsNeutralButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeSecondaryButtonBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}" />
            <Setter Property="Padding" Value="15,7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ThemeSecondaryButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ThemeSecondaryButtonPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource ThemeBackgroundBrush}" CornerRadius="12" BorderBrush="{DynamicResource AccentColorBrush}" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar / Header (Draggable, Rounded Corners clipping fix) -->
            <Border Grid.Row="0" Background="{DynamicResource ThemeHeaderBackgroundBrush}" CornerRadius="10,10,0,0" MouseDown="TitleBar_MouseDown" SnapsToDevicePixels="True">
                <Grid>
                    <TextBlock Text="{Binding Loc[PanelTitle]}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="13" FontWeight="Bold" 
                               VerticalAlignment="Center" Margin="15,0,0,0" />
                    
                    <!-- Settings Button (Gear) -->
                    <Button Content="☰" Command="{Binding ToggleSettingsCommand}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Background="Transparent" 
                            BorderThickness="0" HorizontalAlignment="Right" FontSize="18" Width="40" Height="40" Margin="0,0,40,0" Cursor="Hand" ToolTip="{Binding Loc[SettingsTooltip]}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentColorBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Close Button -->
                    <Button Content="✕" Click="Close_Click" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Background="Transparent" 
                            BorderThickness="0" HorizontalAlignment="Right" FontSize="14" Width="40" Height="40" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ef4444"/>
                                        <Setter Property="Foreground" Value="#ffffff"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Panel Content -->
            <Grid Grid.Row="1" Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" /> <!-- List / Search Column -->
                    <ColumnDefinition Width="Auto" /> <!-- Splitter -->
                    <ColumnDefinition Width="*" />   <!-- Display / Editor / Settings Column -->
                </Grid.ColumnDefinitions>

                <!-- Left Column: Search & List -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Search Input (uses modern global TextBox style) -->
                    <TextBox x:Name="SearchTextBox" Grid.Row="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Margin="0,0,0,8" Padding="10,7" Height="36"/>

                    <!-- Filters Row: Type Filter & Tag Filter in two columns -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Type Filter Column -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Loc[TypeFilterLabel]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="10.5" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding TypeFilters}" 
                                      SelectedValuePath="Key" 
                                      DisplayMemberPath="DisplayName" 
                                      SelectedValue="{Binding SelectedTypeFilter, UpdateSourceTrigger=PropertyChanged}" 
                                      Height="30" 
                                      VerticalContentAlignment="Center" />
                        </StackPanel>
                        
                        <!-- Tag Filter Column -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding Loc[TagFilterLabel]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="10.5" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding DynamicTags}" SelectedItem="{Binding SelectedTagFilter}" Height="30" VerticalContentAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!-- Actions: Add Buttons -->
                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" Content="{Binding Loc[AddItem]}" Command="{Binding AddCommand}" 
                                Background="{DynamicResource AccentColorBrush}" Foreground="#ffffff" BorderThickness="0" Padding="0,8"
                                FontWeight="Bold" FontSize="12" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="6" />
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentColorBrushMouseOver}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="2" Content="{Binding Loc[AddFromClipboard]}" Command="{Binding AddFromClipboardCommand}" 
                                Background="{DynamicResource ThemeSecondaryButtonBgBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderThickness="0" Padding="0,8"
                                FontWeight="Bold" FontSize="12" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="6" />
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ThemeSecondaryButtonHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- Prompts ListBox (Clean custom scrollbars apply globally) -->
                    <ListBox x:Name="PromptsListBox" Grid.Row="3" ItemsSource="{Binding Prompts}" SelectedItem="{Binding SelectedPrompt}"
                             Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Name and Badges -->
                                    <Grid Grid.Row="0" Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Title -->
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="13.5" FontWeight="Bold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        
                                        <!-- Badges Row -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                                            <!-- Pinned Icon (Show only when IsPinned is True) -->
                                            <TextBlock Text="📌" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"
                                                       Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            
                                            <!-- Favorite Star (Show only when IsFavorite is True) -->
                                            <TextBlock Text="★" Foreground="#fbbf24" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                       Visibility="{Binding IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            
                                            <!-- Type Badge -->
                                            <Border CornerRadius="3" Padding="5,1.5" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource TypeBadgePromptBg}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ItemType}" Value="Command">
                                                                <Setter Property="Background" Value="{DynamicResource TypeBadgeCommandBg}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ItemType}" Value="Snippet">
                                                                <Setter Property="Background" Value="{DynamicResource TypeBadgeSnippetBg}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ItemType}" Value="Note">
                                                                <Setter Property="Background" Value="{DynamicResource TypeBadgeNoteBg}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TypeBadgePromptText}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Prompt" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ItemType}" Value="Prompt">
                                                                    <Setter Property="Text" Value="Prompt" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource TypeBadgePromptText}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ItemType}" Value="Command">
                                                                    <Setter Property="Text" Value="命令" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource TypeBadgeCommandText}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ItemType}" Value="Snippet">
                                                                    <Setter Property="Text" Value="片段" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource TypeBadgeSnippetText}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ItemType}" Value="Note">
                                                                    <Setter Property="Text" Value="笔记" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource TypeBadgeNoteText}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <!-- Tags list -->
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Tags}" Margin="0,0,0,6">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource ThemeSecondaryButtonBgBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,5,3">
                                                    <TextBlock Text="{Binding}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="10"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Content Preview -->
                                    <TextBlock Grid.Row="2" Text="{Binding Content}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" 
                                               TextTrimming="CharacterEllipsis" Height="32"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Column Splitter Line -->
                <Border Grid.Column="1" Width="1" Background="{DynamicResource ThemeBorderBrush}" Margin="15,0" HorizontalAlignment="Center"/>

                <!-- Right Column: Flat mutually exclusive Views (guarantees no dependency property precedence traps) -->
                <Grid Grid.Column="2">
                    
                    <!-- 1. EMPTY STATE VIEW -->
                    <Grid x:Name="EmptyStateView" Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📁" FontSize="48" Foreground="{DynamicResource ThemeTextDisabledBrush}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="{Binding Loc[EmptyStateTitle]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Loc[EmptyStateHint]}" Foreground="{DynamicResource ThemeTextDisabledBrush}" FontSize="11.5" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- 2. EDITOR VIEW -->
                    <Grid x:Name="EditorView" Visibility="{Binding IsEditorVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Title -->
                        <TextBlock Grid.Row="0" Text="{Binding EditorTitle}" Foreground="{DynamicResource AccentColorBrush}" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                        <!-- Edit Scroll Form -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,0">
                                <!-- Name -->
                                <TextBlock Text="{Binding Loc[ItemName]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="0,0,0,15" Padding="10,6" Height="36" />

                                <!-- Item Type Selection -->
                                <TextBlock Text="{Binding Loc[TypeFilterLabel]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" Margin="0,0,0,5"/>
                                <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding EditingItemType, UpdateSourceTrigger=PropertyChanged}" 
                                          Margin="0,0,0,15" Height="34" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="Prompt" Tag="Prompt"/>
                                    <ComboBoxItem Content="{Binding Loc[Command]}" Tag="Command"/>
                                    <ComboBoxItem Content="{Binding Loc[Snippet]}" Tag="Snippet"/>
                                    <ComboBoxItem Content="{Binding Loc[Note]}" Tag="Note"/>
                                </ComboBox>

                                <!-- Tags separated by commas/semicolons -->
                                <TextBlock Text="{Binding Loc[Tags]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingTagsText, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="0,0,0,5" Padding="10,6" Height="36" />
                                <TextBlock Text="* 本项目使用 AI 辅助开发（包括 Code Review）" 
                                           Foreground="{DynamicResource ThemeTextDisabledBrush}" FontSize="10.5" TextWrapping="Wrap" Margin="0,0,0,15"/>

                                <!-- Content -->
                                <TextBlock Text="{Binding Loc[ItemContent]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingContent, UpdateSourceTrigger=PropertyChanged}" 
                                         AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap" Height="185"
                                         Padding="10" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Error Message & Editor Actions -->
                        <Grid Grid.Row="2" Margin="0,15,0,0">
                            <TextBlock Text="{Binding EditorError}" Foreground="#f87171" FontSize="11.5" VerticalAlignment="Center" 
                                       TextWrapping="Wrap" Width="260" HorizontalAlignment="Left"/>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="{Binding Loc[Cancel]}" Command="{Binding CancelEditCommand}" 
                                        Background="{DynamicResource ThemeSecondaryButtonBgBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderThickness="0" Padding="20,7" Margin="0,0,10,0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="6" />
                                        </Style>
                                    </Button.Resources>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ThemeSecondaryButtonHoverBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                
                                <Button Content="{Binding Loc[Save]}" Command="{Binding SavePromptCommand}" 
                                        Background="{DynamicResource AccentColorBrush}" Foreground="#ffffff" BorderThickness="0" Padding="20,7" FontWeight="Bold" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="6" />
                                        </Style>
                                    </Button.Resources>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentColorBrushMouseOver}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
 
                    <!-- 3. SETTINGS VIEW -->
                    <Grid x:Name="SettingsView" Visibility="{Binding IsSettingsPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Title -->
                        <TextBlock Grid.Row="0" Text="{Binding Loc[SettingsTitle]}" Foreground="{DynamicResource AccentColorBrush}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                        <!-- Settings TabControl -->
                        <TabControl Grid.Row="1">
                            <!-- Tab 1: 常规设置 -->
                            <TabItem Header="{Binding Loc[GeneralSettings]}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Loc[Language]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,10,0,10"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <RadioButton Content="{Binding Loc[Chinese]}" IsChecked="{Binding IsLanguageChinese}"
                                                         Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,25,0" Cursor="Hand" />
                                            <RadioButton Content="{Binding Loc[English]}" IsChecked="{Binding IsLanguageEnglish}"
                                                         Foreground="{DynamicResource ThemeTextPrimaryBrush}" Cursor="Hand" />
                                        </StackPanel>

                                        <!-- Section 1: Theme selection -->
                                        <TextBlock Text="{Binding Loc[Theme]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <RadioButton Content="{Binding Loc[DarkMode]}" IsChecked="{Binding IsThemeDark}" 
                                                          Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,25,0" Cursor="Hand" />
                                            <RadioButton Content="{Binding Loc[LightMode]}" IsChecked="{Binding IsThemeLight}" 
                                                          Foreground="{DynamicResource ThemeTextPrimaryBrush}" Cursor="Hand" />
                                        </StackPanel>

                                        <!-- Section 2: Accent color selection -->
                                        <TextBlock Text="{Binding Loc[AccentColor]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" Margin="4,0,0,15">
                                            <RadioButton Style="{StaticResource ColorBadgeStyle}" Background="#7c3aed" BorderBrush="#a78bfa" Content="Purple" IsChecked="{Binding IsAccentPurple}" ToolTip="紫色" />
                                            <RadioButton Style="{StaticResource ColorBadgeStyle}" Background="#3b82f6" BorderBrush="#93c5fd" Content="Blue" IsChecked="{Binding IsAccentBlue}" ToolTip="蓝色" />
                                            <RadioButton Style="{StaticResource ColorBadgeStyle}" Background="#10b981" BorderBrush="#6ee7b7" Content="Green" IsChecked="{Binding IsAccentGreen}" ToolTip="绿色" />
                                            <RadioButton Style="{StaticResource ColorBadgeStyle}" Background="#f97316" BorderBrush="#fdba74" Content="Orange" IsChecked="{Binding IsAccentOrange}" ToolTip="橙色" />
                                            <RadioButton Style="{StaticResource ColorBadgeStyle}" Background="#ec4899" BorderBrush="#fbcfe8" Content="Pink" IsChecked="{Binding IsAccentPink}" ToolTip="粉色" />
                                        </StackPanel>

                                        <!-- Section 3: Behavioral Preferences -->
                                        <TextBlock Text="{Binding Loc[Behavior]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,10,0,10"/>
                                        <Border Background="{DynamicResource ThemeHeaderBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1.2" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                            <StackPanel>
                                                <CheckBox Content="{Binding Loc[FocusSearch]}" IsChecked="{Binding FocusSearchOnOpen}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,0,10" Cursor="Hand"/>
                                                <CheckBox Content="{Binding Loc[SelectSearch]}" IsChecked="{Binding SelectSearchTextOnOpen}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,0,10" Cursor="Hand" IsEnabled="{Binding FocusSearchOnOpen}"/>
                                                <StackPanel Margin="0,0,0,10">
                                                    <CheckBox Content="{Binding Loc[HideAfterCopy]}" IsChecked="{Binding HidePanelAfterCopy}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Cursor="Hand"/>
                                                    <TextBlock Text="{Binding Loc[HideAfterCopyHint]}" Foreground="{DynamicResource ThemeTextDisabledBrush}" FontSize="10.5" Margin="20,4,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <CheckBox Content="{Binding Loc[ClearSearchAfterCopy]}" IsChecked="{Binding ClearSearchAfterCopy}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Cursor="Hand"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Section 4: Resident & Startup -->
                                        <TextBlock Text="{Binding Loc[StartupSection]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,5,0,10"/>
                                        <Border Background="{DynamicResource ThemeHeaderBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1.2" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                                            <StackPanel>
                                                <StackPanel Margin="0,0,0,10">
                                                    <CheckBox Content="{Binding Loc[StartupEnabled]}" IsChecked="{Binding IsStartupEnabled}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Cursor="Hand"/>
                                                    <TextBlock Text="{Binding Loc[StartupHint]}" Foreground="{DynamicResource ThemeTextDisabledBrush}" FontSize="10.5" Margin="20,4,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <TextBlock Text="* 开发调试模式下（包括 bin\Debug 或 dotnet run）不建议开启自动启动。建议在发布（Publish）后的 exe 中开启。" Foreground="{DynamicResource ThemeTextDisabledBrush}" FontSize="10.5" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- Tab 2: 数据管理 -->
                            <TabItem Header="{Binding Loc[DataManagement]}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,0,10,0">
                                        <!-- Section 1: Storage directory -->
                                        <TextBlock Text="{Binding Loc[DataManagement]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,10,0,10"/>
                                        <Border Background="{DynamicResource ThemeHeaderBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1.2" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                            <StackPanel>
                                                <TextBlock Text="{Binding CurrentStoragePath}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12" />
                                                <WrapPanel>
                                                    <Button Content="{Binding Loc[OpenDataDir]}" Command="{Binding OpenStorageDirCommand}" Style="{StaticResource SettingsNeutralButtonStyle}" Margin="0,0,10,10" />
                                                    <Button Content="{Binding Loc[OpenLogsDir]}" Command="{Binding OpenLogsDirCommand}" Style="{StaticResource SettingsNeutralButtonStyle}" Margin="0,0,10,10" />
                                                    <Button Content="{Binding Loc[OpenBackupsDir]}" Command="{Binding OpenBackupsDirCommand}" Style="{StaticResource SettingsNeutralButtonStyle}" Margin="0,0,10,10" />
                                                    <Button Content="{Binding Loc[OpenExportDir]}" Command="{Binding OpenExportDirCommand}" Style="{StaticResource SettingsNeutralButtonStyle}" Margin="0,0,10,10" />
                                                    <Button Content="{Binding Loc[ChangeStorageDir]}" Command="{Binding ChangeStoragePathCommand}" Style="{StaticResource SettingsNeutralButtonStyle}" Margin="0,0,0,10" />
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Section 2: Data migration -->
                                        <TextBlock Text="{Binding Loc[ImportExport]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,5,0,10"/>
                                        <Border Background="{DynamicResource ThemeHeaderBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1.2" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                                            <StackPanel>
                                                <WrapPanel Margin="0,0,0,12">
                                                    <Button Content="{Binding Loc[ExportJson]}" Command="{Binding ExportDataCommand}" Style="{StaticResource SettingsNeutralButtonStyle}" Margin="0,0,10,0" />
                                                    <Button Content="{Binding Loc[ImportJson]}" Command="{Binding ImportDataCommand}" Style="{StaticResource SettingsNeutralButtonStyle}" />
                                                </WrapPanel>
                                                <Border Height="1" Background="{DynamicResource ThemeBorderBrush}" Margin="0,0,0,12"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="{Binding Loc[RestoreBackup]}" Command="{Binding RestoreBackupCommand}" Style="{StaticResource SettingsNeutralButtonStyle}" Margin="0,0,10,0" />
                                                    <Button Content="{Binding Loc[CreateBackup]}" Command="{Binding CreateManualBackupCommand}" Style="{StaticResource SettingsNeutralButtonStyle}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- Tab 3: 标签整理 -->
                            <TabItem Header="{Binding Loc[TagManagement]}">
                                <Grid Margin="0,10,10,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Left: Scrollable list of tags -->
                                    <Border Grid.Column="0" Background="{DynamicResource ThemeHeaderBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1.2" CornerRadius="8" Padding="5">
                                        <ListBox ItemsSource="{Binding TagSummaries}" SelectedItem="{Binding SelectedTagSummary}" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayText}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Padding="4,2"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>

                                    <!-- Right: Action area -->
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                        <TextBlock Text="{Binding Loc[TagPanel]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="13" FontWeight="Bold" Margin="0,0,0,12"/>
                                        
                                        <Grid IsEnabled="{Binding IsTagSelected}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Loc[SelectedTag]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding SelectedTagSummary.TagName}" Foreground="{DynamicResource AccentColorBrush}" FontSize="15" FontWeight="Bold" Margin="0,0,0,15"/>

                                                <TextBlock Text="{Binding Loc[TargetTag]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                                <TextBox Text="{Binding TargetTagName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource {x:Type TextBox}}" Margin="0,0,0,15"/>

                                                <Button Content="{Binding Loc[RenameTag]}" Command="{Binding RenameTagCommand}" Style="{StaticResource SettingsNeutralButtonStyle}" HorizontalAlignment="Left" Width="150" Margin="0,0,0,8"/>
                                                <Button Content="{Binding Loc[MergeTag]}" Command="{Binding MergeTagsCommand}" Style="{StaticResource SettingsNeutralButtonStyle}" HorizontalAlignment="Left" Width="150" Margin="0,0,0,20"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border Height="1" Background="{DynamicResource ThemeBorderBrush}" Margin="0,0,0,20"/>
                                        <TextBlock Text="{Binding Loc[UnusedTags]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                        <Button Content="{Binding Loc[CleanTags]}" Command="{Binding CleanUnusedTagsCommand}" Style="{StaticResource SettingsNeutralButtonStyle}" HorizontalAlignment="Left" Width="150"/>
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <!-- Tab 4: 关于软件 -->
                            <TabItem Header="{Binding Loc[About]}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,10,10,0">
                                        <TextBlock Text="{Binding Loc[AboutSnipDock]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="13" FontWeight="Bold" Margin="0,0,0,15"/>
                                        <Border Background="{DynamicResource ThemeHeaderBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1.2" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Loc[AppName]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="SnipDock" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontWeight="Bold" Margin="0,0,0,8"/>

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Loc[Version]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AppVersion}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,0,8"/>

                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Loc[DataVersion]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DataSchemaVersion}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,0,8"/>

                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding Loc[Stats]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Loc[TotalItems]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding TotalItemsCount}" Foreground="{DynamicResource AccentColorBrush}" FontWeight="Bold" Margin="0,0,15,0"/>
                                                    <TextBlock Text="{Binding Loc[TotalTags]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding TotalTagsCount}" Foreground="{DynamicResource AccentColorBrush}" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="{Binding Loc[SystemPaths]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="13" FontWeight="Bold" Margin="0,5,0,10"/>
                                        <Border Background="{DynamicResource ThemeHeaderBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1.2" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                                            <StackPanel>
                                                <!-- Data Path -->
                                                <TextBlock Text="{Binding Loc[StoragePath]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" Margin="0,0,0,2"/>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding StorageDirectoryPath}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="11.5" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="{Binding Loc[Copy]}" Command="{Binding CopyPathCommand}" CommandParameter="{Binding StorageDirectoryPath}" Style="{StaticResource SettingsNeutralButtonStyle}" Padding="8,3" FontSize="11" Margin="10,0,0,0"/>
                                                </Grid>

                                                <!-- Log Path -->
                                                <TextBlock Text="{Binding Loc[LogsPath]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" Margin="0,0,0,2"/>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding LogsDirectoryPath}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="11.5" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="{Binding Loc[Copy]}" Command="{Binding CopyPathCommand}" CommandParameter="{Binding LogsDirectoryPath}" Style="{StaticResource SettingsNeutralButtonStyle}" Padding="8,3" FontSize="11" Margin="10,0,0,0"/>
                                                </Grid>

                                                <!-- Backup Path -->
                                                <TextBlock Text="{Binding Loc[BackupsPath]}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" Margin="0,0,0,2"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding BackupsDirectoryPath}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="11.5" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="{Binding Loc[Copy]}" Command="{Binding CopyPathCommand}" CommandParameter="{Binding BackupsDirectoryPath}" Style="{StaticResource SettingsNeutralButtonStyle}" Padding="8,3" FontSize="11" Margin="10,0,0,0"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Grid>

                    <!-- 4. DETAIL VIEW -->
                    <Grid x:Name="DetailView" Visibility="{Binding IsDetailVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Title Name with Pin and Star Toggle Buttons -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- Title -->
                            <TextBlock Grid.Column="0" Text="{Binding SelectedPrompt.Name}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="20" FontWeight="Black" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            
                            <!-- Pin Toggle Button -->
                            <Button Grid.Column="1" Command="{Binding TogglePinnedCommand}" Background="Transparent" BorderThickness="0" Margin="10,0,0,0" Cursor="Hand" VerticalAlignment="Center" ToolTip="{Binding Loc[PinnedTooltip]}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock x:Name="PinChar" Text="📌" FontSize="20" Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedPrompt.IsPinned}" Value="True">
                                                            <Setter TargetName="PinChar" Property="Text" Value="📌" />
                                                            <Setter TargetName="PinChar" Property="Opacity" Value="1.0" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedPrompt.IsPinned}" Value="False">
                                                            <Setter TargetName="PinChar" Property="Text" Value="📌" />
                                                            <Setter TargetName="PinChar" Property="Opacity" Value="0.3" />
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="PinChar" Property="Opacity" Value="0.8" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Favorite Toggle Button -->
                            <Button Grid.Column="2" Command="{Binding ToggleFavoriteCommand}" Background="Transparent" BorderThickness="0" Margin="10,0,0,0" Cursor="Hand" VerticalAlignment="Center" ToolTip="{Binding Loc[FavoriteTooltip]}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock x:Name="StarChar" Text="☆" FontSize="24" Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedPrompt.IsFavorite}" Value="True">
                                                            <Setter TargetName="StarChar" Property="Text" Value="★" />
                                                            <Setter TargetName="StarChar" Property="Foreground" Value="#fbbf24" />
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="StarChar" Property="Foreground" Value="#fbbf24" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <!-- Meta Row: Tags, Types, Dates and Usage Count -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,15">
                            <!-- Type and Tags Row -->
                            <WrapPanel VerticalAlignment="Center" Margin="0,0,0,8">
                                <!-- Type Badge -->
                                <Border CornerRadius="4" Padding="7,2.5" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource TypeBadgePromptBg}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPrompt.ItemType}" Value="Command">
                                                    <Setter Property="Background" Value="{DynamicResource TypeBadgeCommandBg}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedPrompt.ItemType}" Value="Snippet">
                                                    <Setter Property="Background" Value="{DynamicResource TypeBadgeSnippetBg}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedPrompt.ItemType}" Value="Note">
                                                    <Setter Property="Background" Value="{DynamicResource TypeBadgeNoteBg}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="10.5" FontWeight="Bold" Foreground="{DynamicResource TypeBadgePromptText}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Prompt" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedPrompt.ItemType}" Value="Prompt">
                                                        <Setter Property="Text" Value="Prompt" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TypeBadgePromptText}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedPrompt.ItemType}" Value="Command">
                                                        <Setter Property="Text" Value="命令" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TypeBadgeCommandText}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedPrompt.ItemType}" Value="Snippet">
                                                        <Setter Property="Text" Value="片段" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TypeBadgeSnippetText}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedPrompt.ItemType}" Value="Note">
                                                        <Setter Property="Text" Value="笔记" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TypeBadgeNoteText}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- Tags list -->
                                <ItemsControl ItemsSource="{Binding SelectedPrompt.Tags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource AccentColorSelectedBgBrush}" BorderBrush="{DynamicResource AccentColorBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding}" Foreground="{DynamicResource AccentColorTextBrush}" FontSize="10.5"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </WrapPanel>

                            <!-- Dates & Usage Stats -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Foreground="{DynamicResource ThemeTextDisabledBrush}" FontSize="10.5" VerticalAlignment="Center">
                                    <Run Text="{Binding Loc[CreatedAt]}" />
                                    <Run Text="{Binding SelectedPrompt.UpdatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}, Converter={StaticResource TimeZoneConverter}}" />
                                </TextBlock>
                                
                                <TextBlock Grid.Column="1" Foreground="{DynamicResource ThemeTextDisabledBrush}" FontSize="10.5" VerticalAlignment="Center" TextAlignment="Right">
                                    <Run Text="{Binding Loc[UsageCount]}" />
                                    <Run Text="{Binding SelectedPrompt.UsageCount}" />
                                    <Run Text="{Binding Loc[LastUsed]}" />
                                    <Run Text="{Binding SelectedPrompt.LastUsedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}, TargetNullValue='未使用', Converter={StaticResource TimeZoneConverter}}" />
                                </TextBlock>
                            </Grid>
                        </StackPanel>

                        <!-- Content view box (Uses custom ScrollBars cleanly) -->
                        <Border Grid.Row="2" Background="{DynamicResource ThemeHeaderBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" CornerRadius="8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                                <!-- Style={x:Null} isolates from TextBox global triggers, keeping text selectable and theme-adaptive -->
                                <TextBox Style="{x:Null}" Text="{Binding SelectedPrompt.Content, Mode=OneWay}" 
                                         Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ThemeTextPrimaryBrush}" 
                                         FontSize="12.5" TextWrapping="Wrap" IsReadOnly="True" AcceptsReturn="True" CaretBrush="{DynamicResource ThemeTextPrimaryBrush}" />
                            </ScrollViewer>
                        </Border>

                        <!-- Actions row -->
                        <Grid Grid.Row="3" Margin="0,15,0,0">
                            <!-- Left: Copy action -->
                            <Button Content="{Binding Loc[CopyContent]}" Command="{Binding CopyContentCommand}" CommandParameter="{Binding SelectedPrompt.Content}"
                                    Background="{DynamicResource AccentColorBrush}" Foreground="#ffffff" BorderThickness="0" Padding="22,9" FontWeight="Bold" FontSize="12.5" HorizontalAlignment="Left" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="CornerRadius" Value="6" />
                                    </Style>
                                </Button.Resources>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentColorBrushMouseOver}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Right: Edit / Delete actions -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="{Binding Loc[Edit]}" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedPrompt}"
                                        Background="{DynamicResource ThemeSecondaryButtonBgBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" BorderThickness="0" Padding="18,8" Margin="0,0,10,0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="6" />
                                        </Style>
                                    </Button.Resources>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ThemeSecondaryButtonHoverBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="{Binding Loc[Delete]}" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedPrompt}"
                                        Background="#b91c1c" Foreground="#ffffff" BorderThickness="0" Padding="18,8" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="6" />
                                        </Style>
                                    </Button.Resources>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#ef4444"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
            
            <!-- Toast notification panel overlay -->
            <Border x:Name="ToastBorder" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,30" 
                    Padding="18,10" CornerRadius="8" BorderThickness="1.5" Panel.ZIndex="999" SnapsToDevicePixels="True"
                    Visibility="{Binding IsToastVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <!-- Trigger border colors dynamically -->
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource ThemeCardBackgroundBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsToastSuccess}" Value="False">
                                <Setter Property="BorderBrush" Value="#ef4444" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#000000" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Icon -->
                    <TextBlock Text="✎" Foreground="{DynamicResource AccentColorTextBrush}" FontWeight="Bold" FontSize="14.5" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsToastSuccess}" Value="False">
                                        <Setter Property="Text" Value="✔" />
                                        <Setter Property="Foreground" Value="#ef4444" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Message -->
                    <TextBlock Text="{Binding ToastMessage}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="12.5" FontWeight="Medium" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>


