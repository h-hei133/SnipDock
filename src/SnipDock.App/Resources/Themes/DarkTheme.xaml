<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme Core Color Palette -->
    <SolidColorBrush x:Key="ThemeBackgroundBrush" Color="#121214" />
    <SolidColorBrush x:Key="ThemeCardBackgroundBrush" Color="#1e1e24" />
    <SolidColorBrush x:Key="ThemeBorderBrush" Color="#2d2d34" />
    <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#f3f4f6" />
    <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#9ca3af" />
    <SolidColorBrush x:Key="ThemeTextDisabledBrush" Color="#4b5563" />
    <SolidColorBrush x:Key="ThemeCardHoverBrush" Color="#272730" />
    <SolidColorBrush x:Key="ThemeInputBgBrush" Color="#1e1e24" />
    
    <!-- ScrollBar Brushes for Dark Theme -->
    <SolidColorBrush x:Key="ThemeScrollBarTrackBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ThemeScrollBarThumbBrush" Color="#374151" />
    <SolidColorBrush x:Key="ThemeScrollBarThumbHoverBrush" Color="#4b5563" />
    
    <!-- Dialog Header Background -->
    <SolidColorBrush x:Key="ThemeHeaderBackgroundBrush" Color="#1c1c20" />

    <!-- Secondary Button Brushes for Dark Theme -->
    <SolidColorBrush x:Key="ThemeSecondaryButtonBgBrush" Color="#374151" />
    <SolidColorBrush x:Key="ThemeSecondaryButtonHoverBrush" Color="#4b5563" />
    <SolidColorBrush x:Key="ThemeSecondaryButtonPressedBrush" Color="#1f2937" />

    <!-- Type Badges for Dark Theme -->
    <SolidColorBrush x:Key="TypeBadgePromptBg" Color="#374151" />
    <SolidColorBrush x:Key="TypeBadgeCommandBg" Color="#1e3a8a" />
    <SolidColorBrush x:Key="TypeBadgeSnippetBg" Color="#065f46" />
    <SolidColorBrush x:Key="TypeBadgeNoteBg" Color="#78350f" />
    
    <SolidColorBrush x:Key="TypeBadgePromptText" Color="#d1d5db" />
    <SolidColorBrush x:Key="TypeBadgeCommandText" Color="#93c5fd" />
    <SolidColorBrush x:Key="TypeBadgeSnippetText" Color="#6ee7b7" />
    <SolidColorBrush x:Key="TypeBadgeNoteText" Color="#fde047" />
</ResourceDictionary>
