<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Light Theme Core Color Palette -->
    <SolidColorBrush x:Key="ThemeBackgroundBrush" Color="#f9fafb" />
    <SolidColorBrush x:Key="ThemeCardBackgroundBrush" Color="#ffffff" />
    <SolidColorBrush x:Key="ThemeBorderBrush" Color="#e5e7eb" />
    <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#111827" />
    <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#4b5563" />
    <SolidColorBrush x:Key="ThemeTextDisabledBrush" Color="#9ca3af" />
    <SolidColorBrush x:Key="ThemeCardHoverBrush" Color="#f3f4f6" />
    <SolidColorBrush x:Key="ThemeInputBgBrush" Color="#ffffff" />
    
    <!-- ScrollBar Brushes for Light Theme -->
    <SolidColorBrush x:Key="ThemeScrollBarTrackBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ThemeScrollBarThumbBrush" Color="#d1d5db" />
    <SolidColorBrush x:Key="ThemeScrollBarThumbHoverBrush" Color="#9ca3af" />
    
    <!-- Dialog Header Background -->
    <SolidColorBrush x:Key="ThemeHeaderBackgroundBrush" Color="#f3f4f6" />

    <!-- Secondary Button Brushes for Light Theme -->
    <SolidColorBrush x:Key="ThemeSecondaryButtonBgBrush" Color="#e5e7eb" />
    <SolidColorBrush x:Key="ThemeSecondaryButtonHoverBrush" Color="#d1d5db" />
    <SolidColorBrush x:Key="ThemeSecondaryButtonPressedBrush" Color="#9ca3af" />

    <!-- Type Badges for Light Theme -->
    <SolidColorBrush x:Key="TypeBadgePromptBg" Color="#f3f4f6" />
    <SolidColorBrush x:Key="TypeBadgeCommandBg" Color="#dbeafe" />
    <SolidColorBrush x:Key="TypeBadgeSnippetBg" Color="#d1fae5" />
    <SolidColorBrush x:Key="TypeBadgeNoteBg" Color="#fef3c7" />
    
    <SolidColorBrush x:Key="TypeBadgePromptText" Color="#4b5563" />
    <SolidColorBrush x:Key="TypeBadgeCommandText" Color="#1e40af" />
    <SolidColorBrush x:Key="TypeBadgeSnippetText" Color="#065f46" />
    <SolidColorBrush x:Key="TypeBadgeNoteText" Color="#92400e" />
</ResourceDictionary>
