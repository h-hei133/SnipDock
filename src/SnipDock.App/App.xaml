<Application x:Class="SnipDock.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SnipDock.App"
             xmlns:converters="clr-namespace:SnipDock.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default theme colors -->
                <ResourceDictionary Source="Resources/Themes/DarkTheme.xaml" />
                <!-- Master stylesheets referencing dynamic theme colors -->
                <ResourceDictionary Source="Resources/Themes/ThemeResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Converters -->
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:TimeZoneConverter x:Key="TimeZoneConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
